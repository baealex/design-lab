{
  "name": "design-lab",
  "version": "1.0.0",
  "description": "An interactive archive of interface history, design trends, original UI concepts, and visual effects.",
  "scripts": {
    "dev": "ts-node cli/dev.ts",
    "build": "ts-node cli/build.ts",
    "test": "npm run test:unit",
    "test:unit": "node --test -r ts-node/register cli/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "lint": "eslint --ext .ts,.js ./cli ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baealex/design-lab.git"
  },
  "author": "BaeJino",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/baealex/design-lab/issues"
  },
  "homepage": "https://design.baejino.com",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "chokidar": "^3.6.0",
    "eslint": "^8.55.0",
    "eslint-plugin-html": "^7.1.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "parse5": "^7.3.0",
    "sass": "^1.101.0",
    "socket.io": "^4.7.2",
    "terser": "^5.37.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
